{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "timestamp": { "type": "string", "format": "date-time" },
    "alarms": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "severity": { "type": "string" },
          "message": { "type": "string" }
        },
        "required": ["code", "severity"]
      }
    }
  },
  "required": ["timestamp", "alarms"]
}
